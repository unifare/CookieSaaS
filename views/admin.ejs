<%- include('header') %>

<!-- User Management Section -->
<div>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h3 style="margin: 0;">User Management</h3>
    <button class="btn" style="display: flex; align-items: center; gap: 8px;" onclick="document.getElementById('addUserModal').style.display='flex'">
      <i data-lucide="user-plus" style="width: 16px; height: 16px;"></i> Add User
    </button>
  </div>
  
  <div style="overflow-x: auto; background: white; border-radius: 12px; border: 1px solid rgba(0,0,0,0.06);">
    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14px;">
      <thead>
        <tr style="background: #fbfbfd; border-bottom: 1px solid rgba(0,0,0,0.06);">
          <th style="padding: 12px 16px; font-weight: 600;">ID</th>
          <th style="padding: 12px 16px; font-weight: 600;">Username</th>
          <th style="padding: 12px 16px; font-weight: 600;">Role</th>
          <th style="padding: 12px 16px; font-weight: 600;">Status</th>
          <th style="padding: 12px 16px; font-weight: 600;">API Token</th>
          <th style="padding: 12px 16px; font-weight: 600; text-align: right;">Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr style="border-bottom: 1px solid rgba(0,0,0,0.04);">
            <td style="padding: 12px 16px;"><%= u.id %></td>
            <td style="padding: 12px 16px; font-weight: 500;"><%= u.username %></td>
            <td style="padding: 12px 16px;"><%= u.role %></td>
            <td style="padding: 12px 16px;">
              <% if (u.is_active === 1) { %>
                <span style="color: #34c759; font-weight: 600;">Active</span>
              <% } else { %>
                <span style="color: #ff3b30; font-weight: 600;">Disabled</span>
              <% } %>
            </td>
            <td style="padding: 12px 16px; font-family: monospace; color: #86868b;"><%= u.api_token.substring(0, 10) %>...</td>
            <td style="padding: 12px 16px; text-align: right;">
              <% if (u.id !== user.id) { %>
                <button class="btn" style="padding: 4px 8px; font-size: 12px; margin-right: 4px; background: #e5e5ea; color: #1d1d1f;" onclick="openResetModal(<%= u.id %>, '<%= u.username %>')">Reset Pwd</button>
                
                <% if (u.is_active === 1) { %>
                  <button class="btn btn-danger" style="padding: 4px 8px; font-size: 12px; margin-right: 4px;" onclick="toggleStatus(<%= u.id %>, false)">Disable</button>
                <% } else { %>
                  <button class="btn" style="padding: 4px 8px; font-size: 12px; margin-right: 4px; background: #34c759;" onclick="toggleStatus(<%= u.id %>, true)">Enable</button>
                <% } %>
                
                <button class="btn btn-danger" style="padding: 4px 8px; font-size: 12px;" onclick="deleteUser(<%= u.id %>)">Delete</button>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Add User Modal -->
<div id="addUserModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000; align-items: center; justify-content: center; padding: 16px;">
  <div class="card" style="width: 100%; max-width: 400px; margin: auto;">
    <h3 style="margin-top: 0; margin-bottom: 16px;">Add New User</h3>
    <input type="text" id="addUsername" class="input-field" placeholder="Username" />
    <input type="password" id="addPassword" class="input-field" placeholder="Password" />
    <select id="addRole" class="input-field">
      <option value="user">User</option>
      <option value="admin">Admin</option>
    </select>
    <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 8px;">
      <button class="btn" style="background: #e5e5ea; color: #1d1d1f;" onclick="document.getElementById('addUserModal').style.display='none'">Cancel</button>
      <button class="btn" onclick="submitAddUser()">Add User</button>
    </div>
  </div>
</div>

<!-- Reset Password Modal -->
<div id="resetModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000; align-items: center; justify-content: center; padding: 16px;">
  <div class="card" style="width: 100%; max-width: 400px; margin: auto;">
    <h3 style="margin-top: 0; margin-bottom: 16px;">Reset Password for <span id="resetUsername" style="color: var(--primary);"></span></h3>
    <input type="hidden" id="resetUserId" />
    <input type="password" id="adminNewPwd" class="input-field" placeholder="Enter new password" />
    <div style="display: flex; justify-content: flex-end; gap: 12px;">
      <button class="btn" style="background: #e5e5ea; color: #1d1d1f;" onclick="document.getElementById('resetModal').style.display='none'">Cancel</button>
      <button class="btn btn-danger" onclick="submitResetPassword()">Force Reset</button>
    </div>
  </div>
</div>

<script>
  async function toggleReg(enable) {
    try {
      await axios.post('/api/admin/settings/registration', { enabled: enable });
      window.location.reload();
    } catch(e) {
      alert('Failed');
    }
  }

  async function submitAddUser() {
    const user = document.getElementById('addUsername').value;
    const pass = document.getElementById('addPassword').value;
    const role = document.getElementById('addRole').value;
    if (!user || !pass) return alert('Username and password are required');
    
    try {
      await axios.post('/api/admin/users', { username: user, password: pass, role });
      window.location.reload();
    } catch(e) {
      alert(e.response?.data?.error || 'Failed to add user');
    }
  }

  function openResetModal(id, username) {
    document.getElementById('resetUserId').value = id;
    document.getElementById('resetUsername').innerText = username;
    document.getElementById('adminNewPwd').value = '';
    document.getElementById('resetModal').style.display = 'flex';
  }

  async function submitResetPassword() {
    const id = document.getElementById('resetUserId').value;
    const pwd = document.getElementById('adminNewPwd').value;
    if (!pwd) return alert('Enter a password');
    
    try {
      await axios.post(`/api/admin/users/${id}/reset-password`, { newPassword: pwd });
      alert('Password reset successfully');
      document.getElementById('resetModal').style.display = 'none';
    } catch(e) {
      alert(e.response?.data?.error || 'Failed to reset password');
    }
  }

  async function toggleStatus(id, isActive) {
    const action = isActive ? 'ENABLE' : 'DISABLE (Disconnect all sessions)';
    if(!confirm(`Are you sure you want to ${action} this user?`)) return;
    try {
      await axios.post(`/api/admin/users/${id}/toggle-status`, { isActive });
      window.location.reload();
    } catch(e) {
      alert(e.response?.data?.error || 'Failed to toggle status');
    }
  }

  async function deleteUser(id) {
    if(!confirm('Delete this user AND ALL THEIR COOKIES?')) return;
    try {
      await axios.delete(`/api/admin/users/${id}`);
      window.location.reload();
    } catch(e) {
      alert('Failed');
    }
  }
</script>

<%- include('footer') %>
